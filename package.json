{
  "name": "phoenix-atlas",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "copy-api": "cp -R ./api ./docs/api",
    "deploy": "ng build --configuration production --base-href \"./\" && rm -rf ./docs && cp -R dist/phoenix-atlas ./docs && cp ./docs/index.html ./docs/404.html",
    "deploy:single": "ng build --configuration singleEvent --base-href \"./\" && rm -rf ./docs && cp -R dist/phoenix-atlas ./docs && cp ./docs/index.html ./docs/404.html"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "20.2.14",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "check-dependencies": "^1.1.0",
    "phoenix-event-display": "^4.0.0",
    "phoenix-ui-components": "^4.0.1",
    "rxjs": "^7.8.0",
    "tslib": "^2.5.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.31",
    "@angular/cli": "20.3.31",
    "@angular/compiler-cli": "20.3.25",
    "@types/node": "^18.14.6",
    "husky": "^8.0.3",
    "prettier": "^2.8.4",
    "pretty-quick": "^3.1.3",
    "typescript": "~5.8.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "resolutions": {
    "canvas": "^3.2.3"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
